// =====================================================================
// RÈGLES DE SÉCURITÉ FIRESTORE
// =====================================================================
// À copier dans : Console Firebase > Firestore Database > Règles
//
// Pourquoi ces règles sont nécessaires :
// Le verrouillage des pronostics dans app.js (côté client) est facile à
// contourner par un utilisateur un peu averti (console du navigateur).
// Ces règles imposent la contrainte directement côté serveur Firebase,
// ce qui la rend réellement infranchissable.
// =====================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profils utilisateurs : chacun peut lire (pour vérifier l'unicité
    // des identifiants et afficher les noms), mais seul le propriétaire
    // peut créer son propre profil, et personne ne peut le modifier après.
    match /users/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Pronostics : chacun peut lire tous les pronostics (nécessaire pour
    // calculer le classement collectif). La création n'est permise que
    // si le document n'existe pas déjà (empêche la double soumission) et
    // que l'utilisateur ne pronostique que pour lui-même. Toute
    // modification ou suppression ultérieure est interdite.
    match /bets/{betId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && resource == null;
      allow update, delete: if false;
    }
  }
}
